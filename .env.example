# Beacon Dashboard Configuration
# Copy this to .env.local and fill in your values

# Authentication (REQUIRED)
MC_USERNAME=admin
MC_PASSWORD=changeme
SESSION_SECRET=generate-a-random-string-at-least-32-chars

# Prometheus API connection
NEXT_PUBLIC_API_BASE=http://localhost:8005
NEXT_PUBLIC_WS_URL=ws://localhost:8010

# Prometheus gateway
PROMETHEUS_GATEWAY_URL=ws://localhost:8010
PROMETHEUS_GATEWAY_TOKEN=

# Workspace
WORKSPACE_ROOT=~/.prometheus/workspace

# Ports
PORT=3002

# Remote gateways (optional, pipe-delimited: name|host|url|token)
# REMOTE_GATEWAYS=gpu-node|gpu-node|ws://192.168.1.100:18789|your-token
